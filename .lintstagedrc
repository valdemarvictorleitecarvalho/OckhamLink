{
  "frontend/src/**/*.{ts,tsx}": [
    "npm --prefix frontend exec -- prettier --write",
    "npm --prefix frontend exec -- eslint --fix"
  ],
  "backend/src/**/*.ts": [
    "npm --prefix backend exec -- prettier --write",
    "env ESLINT_USE_FLAT_CONFIG=true npm --prefix backend exec -- eslint --fix --config backend/eslint.config.mjs"
  ]
}
